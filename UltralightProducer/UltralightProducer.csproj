<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\UltralightUnity\UltralightUnity.csproj" />

    <EmbeddedResource Include="libs/libAppCore.so" />
    <EmbeddedResource Include="libs/libUltralight.so" />
    <EmbeddedResource Include="libs/libUltralightCore.so" />
    <EmbeddedResource Include="libs/libWebCore.so" />
    <None Include="resources/**" CopyToOutputDirectory="Always" />
  </ItemGroup>

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>

    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>

    <RuntimeIdentifier>linux-x64</RuntimeIdentifier>
  </PropertyGroup>
</Project>